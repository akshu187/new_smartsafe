# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/smartsafe
ENABLE_IN_MEMORY_DB_FALLBACK=false

# JWT Configuration (use long random secrets in production)
JWT_ACCESS_SECRET=replace-with-32-plus-char-random-access-secret
JWT_REFRESH_SECRET=replace-with-32-plus-char-random-refresh-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cookie/CORS Configuration
# Use FRONTEND_URLS for multiple origins (comma-separated)
FRONTEND_URL=http://localhost:3000
# FRONTEND_URLS=http://localhost:3000,https://app.example.com

# Socket.io CORS (comma-separated supported)
SOCKET_CORS_ORIGIN=http://localhost:3000
# SOCKET_CORS_ORIGINS=http://localhost:3000,https://app.example.com

# Cookie behavior
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Reverse proxy (set true behind nginx/load balancer)
TRUST_PROXY=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Live incident provider (production safety hardening)
ENABLE_LIVE_INCIDENT_FETCH=false
LIVE_INCIDENT_PROVIDER=tomtom
TOMTOM_API_KEY=
LIVE_INCIDENT_CACHE_TTL_SEC=120
LIVE_INCIDENT_REQUEST_TIMEOUT_MS=7000
LIVE_INCIDENT_MAX_RADIUS_KM=80
